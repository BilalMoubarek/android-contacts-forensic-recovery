import sqlite3
import os

def recover_contacts(db_path):
    """
    Extracts and recovers contact names and phone numbers from Android's contacts2.db
    """
    if not os.path.exists(db_path):
        print(f"[-] Error: File {db_path} not found. Ensure you pulled it via ADB.")
        return

    print(f"[+] Connected to Android Database: {db_path}")
    print("[*] Running forensic extraction query...")

    try:
        conn = sqlite3.connect(db_path)
        cursor = conn.cursor()

        # SQL query to extract raw contact data from system tables
        query = """
        SELECT raw_contacts.display_name, phone_lookup.normalized_number 
        FROM raw_contacts 
        JOIN phone_lookup ON raw_contacts.version = phone_lookup.raw_contact_id
        WHERE raw_contacts.deleted = 0 OR raw_contacts.deleted = 1;
        """
        
        cursor.execute(query)
        rows = cursor.fetchall()

        if not rows:
            print("[-] No contacts found in the database partition.")
            return

        print(f"[+] Successfully extracted {len(rows)} contacts (including deleted files).")
        
        # Outputting to a standard VCF (vCard) file for easy mobile restore
        vcf_filename = "recovered_contacts.vcf"
        with open(vcf_filename, "w", encoding="utf-8") as vcf:
            for name, phone in rows:
                if name and phone:
                    vcf.write("BEGIN:VCARD\n")
                    vcf.write("VERSION:3.0\n")
                    vcf.write(f"FN:{name}\n")
                    vcf.write(f"TEL;TYPE=CELL:{phone}\n")
                    vcf.write("END:VCARD\n")
        
        print(f"[+] Success! Backup compiled into: {vcf_filename}")
        print("[*] You can now import this file directly into any Android/iOS device.")

    except sqlite3.Error as e:
        print(f"[-] Database Error: {e}")
    finally:
        if conn:
            conn.close()

if __name__ == "__main__":
    print("====================================================")
    print("      Mr_Spy's Android Contact Recovery v1.0        ")
    print("====================================================")
    # Path where user places the pulled database from /data/data/com.android.providers.contacts/databases/contacts2.db
    recover_contacts("contacts2.db")
